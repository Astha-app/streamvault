# Server configuration
PORT=3001

# CORS - frontend origin
CLIENT_ORIGIN=http://localhost:5173

# Real-Debrid API token
# Get yours at https://real-debrid.com/apitoken
# SECURITY: Never commit this file with a real token. This value stays server-side only.
REALDEBRID_API_TOKEN=your_realdebrid_token_here

# Cache TTL in minutes for resolved Real-Debrid links (default: 60)
REALDEBRID_CACHE_TTL_MINUTES=60

# Node environment
NODE_ENV=development
